# Copy this file to .env and fill in only the providers you use.

# Chatbot via OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Embeddings
ONEMEM_EMBEDDING_PROVIDER=hash
ONEMEM_EMBEDDING_DIMENSIONS=64

# Gemini embedding mode
# ONEMEM_EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=
# ONEMEM_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# ONEMEM_EMBEDDING_DIMENSIONS=768

